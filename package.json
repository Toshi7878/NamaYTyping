{
  "name": "namaytyping-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm -F userscript dev",
    "build": "pnpm -F userscript build",
    "preview": "pnpm -F userscript preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "check": "biome check --diagnostic-level=warn --reporter=summary",
    "check:fix": "biome check --diagnostic-level=warn --reporter=summary --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13"
  }
}
